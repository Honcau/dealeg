# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Lấy từ: supabase.com → project → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres"

# ─── Cron security ────────────────────────────────────────────────────────────
# Tạo bằng: openssl rand -hex 32
CRON_SECRET="your-random-secret-here"

# ─── Affiliate IDs ────────────────────────────────────────────────────────────
NAMECHEAP_AFFILIATE_ID=""
HOSTINGER_AFFILIATE_ID=""
NORDVPN_AFFILIATE_ID=""
DIGITALOCEAN_AFFILIATE_ID=""

# ─── Tools (Phase 2) ─────────────────────────────────────────────────────────
ILOVEPDF_PUBLIC_KEY=""
ILOVEPDF_SECRET_KEY=""
CLOUDCONVERT_API_KEY=""

# ─── Admin Panel ─────────────────────────────────────────────────────────────
# Tạo bằng: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ADMIN_SECRET="your-admin-password-here"
-e 
# ─── Scraper debug ────────────────────────────────────────────────
SCRAPER_DEBUG=false   # true = lưu HTML vào thư mục debug/

# ─── NextAuth + Google OAuth ───────────────────────────────────────────────────
# Tạo tại: https://console.cloud.google.com
# 1. New project → "dealeg"
# 2. APIs & Services → OAuth 2.0 Credentials → Create OAuth 2.0 Client ID
# 3. Type: Web application
# 4. Authorized redirect URIs:
#    - http://localhost:3000/api/auth/callback/google (dev)
#    - https://dealeg.com/api/auth/callback/google (prod)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# NextAuth secret — tạo bằng: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ─── Facebook OAuth ───────────────────────────────────────────────────────────
# Tạo tại: https://developers.facebook.com
# 1. My Apps → Create App → Consumer
# 2. Add Product: Facebook Login
# 3. Settings → Basic → App ID + App Secret
# 4. Facebook Login → Settings → Valid OAuth Redirect URIs:
#    https://dealeg.com/api/auth/callback/facebook
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# Tạo tại: https://github.com/settings/developers
# 1. New OAuth App
# 2. Authorization callback URL: https://dealeg.com/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── DeepL Translation API ──────────────────────────────────────────────────
# Đăng ký tại: https://www.deepl.com/pro-api
# Free tier: 500,000 ký tự / tháng (~50 bài viết dài)
# API key kết thúc bằng :fx = Free tier
DEEPL_API_KEY=""
