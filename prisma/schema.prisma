generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Category {
  DOMAIN
  HOSTING
  VPN
  SECURITY
  EMAIL
  CDN
  SSL
  OTHER
}

enum ScrapeType {
  AFFILIATE_API
  CHEERIO
  PLAYWRIGHT
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

// ── Voucher ───────────────────────────────────────────────────────────────────

model Voucher {
  id            String    @id @default(cuid())
  code          String
  discount      String
  discountValue Float?
  category      Category
  provider      String
  affiliateUrl  String?
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  isVerified    Boolean   @default(false)
  successRate   Float     @default(0)
  useCount      Int       @default(0)
  sourceUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  translations  VoucherTranslation[]
  priceHistory  PriceHistory[]
  saved         SavedVoucher[]
  comments      Comment[]

  @@unique([code, provider])
  @@index([category])
  @@index([provider])
  @@index([isActive, discountValue])
}

model VoucherTranslation {
  id          String  @id @default(cuid())
  voucherId   String
  locale      String
  title       String
  description String  @default("")
  voucher     Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@unique([voucherId, locale])
  @@index([voucherId])
}

model PriceHistory {
  id         String   @id @default(cuid())
  voucherId  String
  price      Float
  recordedAt DateTime @default(now())
  voucher    Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@index([voucherId])
}

// ── Provider ──────────────────────────────────────────────────────────────────

model Provider {
  id              String      @id @default(cuid())
  name            String      @unique
  slug            String      @unique
  website         String
  logo            String?
  category        Category
  hasAffiliateApi Boolean     @default(false)
  affiliateId     String?
  scrapeUrl       String?
  scrapeType      ScrapeType  @default(CHEERIO)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  scraperJobs     ScraperJob[]
}

model ScraperJob {
  id          String    @id @default(cuid())
  providerId  String
  status      JobStatus @default(PENDING)
  foundCount  Int       @default(0)
  newCount    Int       @default(0)
  error       String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime  @default(now())
  provider    Provider  @relation(fields: [providerId], references: [id])

  @@index([providerId])
}

// ── Auth (NextAuth + Prisma Adapter) ─────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  comments      Comment[]
  votes         Vote[]
  saved         SavedVoucher[]
  submissions   VoucherSubmission[]
  alerts        VoucherAlert[]
  createdAt     DateTime  @default(now())
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Community ─────────────────────────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  voucherId String
  userId    String
  text      String   @db.Text
  votes     Vote[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  voucher   Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([voucherId])
  @@index([userId])
}

model Vote {
  id        String  @id @default(cuid())
  commentId String
  userId    String
  value     Int
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([commentId, userId])
  @@index([commentId])
}

model SavedVoucher {
  id        String   @id @default(cuid())
  userId    String
  voucherId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  voucher   Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, voucherId])
}

model VoucherSubmission {
  id        String           @id @default(cuid())
  code      String
  provider  String
  discount  String?
  url       String?
  status    SubmissionStatus @default(PENDING)
  userId    String?
  user      User?            @relation(fields: [userId], references: [id])
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([status])
}

model VoucherAlert {
  id       String   @id @default(cuid())
  userId   String
  category Category
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}

// ── Blog / Articles ────────────────────────────────────────────────────────────

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Article {
  id           String        @id @default(cuid())
  slug         String        @unique
  status       ArticleStatus @default(DRAFT)
  category     String?
  coverImage   String?
  authorId     String?
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  translations ArticleTranslation[]
}

model ArticleTranslation {
  id               String    @id @default(cuid())
  articleId        String
  locale           String
  title            String
  excerpt          String?   @db.Text
  content          String    @db.Text
  isAutoTranslated Boolean   @default(false)
  translatedAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  article          Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, locale])
  @@index([locale])
  @@index([articleId, locale])
}
